# ============================================================
# EcomCreatives — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# ----------------------------------------------------------
# REQUIRED
# ----------------------------------------------------------

# Google Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# ----------------------------------------------------------
# OPTIONAL
# ----------------------------------------------------------

# Admin panel password (default: admin123 — CHANGE THIS in production!)
ADMIN_PASSWORD=change-me-in-production

# Port for the Next.js production server (default: 3000)
# PORT=3000

# Node environment
NODE_ENV=production

# ----------------------------------------------------------
# NOT NEEDED FOR VPS HOSTING
# (these were only required for Vercel + Upstash Redis)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# ----------------------------------------------------------
